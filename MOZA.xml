  <!-- SALVAGE CONTROLS (mode-specific duplicates)                      -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_salvage">
    <action name="v_salvage_toggle_fire_focused">
      <rebind input="js1_button1"/>  <!-- Salvage focused beam fire (reuse trigger) -->
    </action>
    <action name="v_salvage_toggle_gimbal_mode">
      <rebind input="js1_button6"/>  <!-- Toggle salvage gimbal mode (reuse secondary fire) -->
