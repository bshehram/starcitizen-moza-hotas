  <!-- ================================================================ -->
  <!-- FLIGHT CONTROLS & MOVEMENT                                       -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_movement">
    <!-- Primary Flight Controls (MHG Stick - Axes) -->
    <action name="v_pitch">
      <rebind input="js1_y"/>  <!-- Pitch up/down -->
    </action>
    <action name="v_roll">
      <rebind input="js1_x"/>  <!-- Roll left/right -->
    </action>
    <action name="v_yaw">
      <rebind input="js1_rotz"/>  <!-- Yaw left/right (twist) -->
    </action>

    <!-- Strafe Controls (MTQ Right Module "COM" hat, 57-61, the larger hat). Moved off the MHG right
         hat (js1 12/13/14/15, now FREE for weapons/targeting). Center-press 57 is now FREE - VTOL moved to
         the 3-pos switch (49/50, see below). -->
    <action name="v_strafe_up">
      <rebind input="js2_button61"/>  <!-- Strafe up (COM hat up) -->
    </action>
    <action name="v_strafe_down">
      <rebind input="js2_button60"/>  <!-- Strafe down (COM hat down) -->
    </action>
    <action name="v_strafe_right">
      <rebind input="js2_button58"/>  <!-- Strafe right (COM hat right) -->
    </action>
    <action name="v_strafe_left">
      <rebind input="js2_button59"/>  <!-- Strafe left (COM hat left) -->
    </action>

    <!-- Throttle & Speed (MTQ Throttle) -->
    <!-- Forward = analog axis (js2_roty); reverse = button (js2_button34, the rear detent). Reverse is
         binary BY NECESSITY - proportional reverse was fully investigated and is NOT achievable here:
           * MOZA side: the MTQ outputs a unidirectional 0-65535 axis, idle at ~8000 (~12%); it never
             goes negative and Pithouse cannot set a custom center (confirmed in the MOZA software).
           * SC side: neutral is locked to the axis CENTER (32767) and only center-symmetric axis
             options exist (invert/exponent - verified in SC's own actionmaps.xml, e.g. flight_view
             exponent="1"). No profile setting can move neutral to 12%.
         Idle (12%) != center, and neither side can bridge it, so a full-range v_strafe_longitudinal
         would read idle as deep reverse. Button reverse is the correct config for this hardware.
         (Requires MOZA "Detent Button Mapping" ON so the rear detent emits button 34.) -->
    <action name="v_strafe_forward">
      <rebind input="js2_roty"/>  <!-- Main forward throttle axis (idle at bottom = 0 thrust) -->
    </action>
    <action name="v_strafe_back">
      <rebind input="js2_button34"/>  <!-- Reverse: rear-detent button (binary - see note above) -->
    </action>
    <action name="v_space_brake">
      <rebind input="js2_button51"/>  <!-- Space brake - full stop. MTQ Right Module 3-pos switch, MOMENTARY back position (hold to brake; springs back to rest/49 = v_vtol_off, an idempotent SET so re-firing it on every brake release is harmless). Switch rest (49) = VTOL off, forward-latch (50) = VTOL on - see the VTOL block below -->
    </action>
    <action name="v_afterburner">
      <rebind input="js2_button65"/>  <!-- Afterburner boost -->
    </action>
    <action name="v_toggle_jump_request">
      <rebind input="js2_button9"/>  <!-- Engage jump-point (inter-system) travel, e.g. Stanton/Pyro. NOT in-system quantum (js2_button7). MTQ keypad "FD" - sits directly BELOW the quantum-drive key (7/"SPD") to form a travel column. Moved off js1_button56 (AB6 right wing 4, now FREE) -->
    </action>

    <!-- Master Mode (NAV vs SCM) -->
    <action name="v_master_mode_cycle">
      <rebind input="js2_button5"/>  <!-- Cycle master mode - NAV (travel/quantum) vs SCM (combat) -->
    </action>

    <!-- Speed Limiter Controls -->
    <action name="v_ifcs_speed_limiter_increment">
      <rebind input="js2_button12"/>  <!-- Increase speed limiter -->
    </action>
    <action name="v_ifcs_speed_limiter_decrement">
      <rebind input="js2_button11"/>  <!-- Decrease speed limiter -->
    </action>
    <action name="v_ifcs_speed_limiter_toggle">
      <rebind input="js2_button13"/>  <!-- Enable/disable the speed limiter (MTQ upper encoder CENTER PRESS). Self-contained dial: turn 11/12 to set the speed cap, push 13 to switch the cap on/off -->
    </action>

    <!-- Acceleration G-Force Limiter -->
    <action name="v_accel_range_increment">
      <rebind input="js2_button15"/>  <!-- Increase G-force limiter -->
    </action>
    <action name="v_accel_range_decrement">
      <rebind input="js2_button14"/>  <!-- Decrease G-force limiter -->
    </action>

    <!-- Flight Control Assists -->
    <!-- Coupled<->decoupled TOGGLE on the MTQ "COM" strafe-hat CENTER PRESS (js2_button57) - co-located with the
         strafe directions it complements (decoupled = pure Newtonian translation, the mode you enable to strafe
         freely while keeping guns on a target). Moved here off AB6 left wing 1 (js1_button49, now FREE). Deliberately
         NOT on the MTQ 3-pos switch 49/50: that switch's rest (49) re-fires on every space-brake release, which would
         force-recouple every brake (VTOL tolerates that slot because re-asserting v_vtol_off is harmless; recoupling
         is not). 57 is a plain press unrelated to the brake-return switch, so decoupled still survives braking. -->
    <action name="v_ifcs_vector_decoupling_toggle">
      <rebind input="js2_button57"/>  <!-- Toggle coupled/decoupled - MTQ "COM" strafe-hat CENTER PRESS -->
    </action>
    <action name="v_ifcs_toggle_esp">
      <rebind input="js2_button63"/>  <!-- Toggle ESP (aim-assist input dampening) - MTQ throttle DIAL forward/CW click. Groups the flight assists on the throttle (decoupled = 57, G-Safe = 16). Moved off js1_button50 (AB6 left wing 2, now FREE). NOTE: the dial is an incremental encoder, so each click = one toggle -->
    </action>
    <action name="v_ifcs_toggle_gforce_safety">
      <rebind input="js2_button16"/>  <!-- Toggle G-Safe (MTQ lower encoder CENTER PRESS). Self-contained dial: turn 14/15 to set the accel/G cap, push 16 to toggle the G-safety that governs it. MOVED here from js1_button51 (AB6 left wing 3), which is now FREE -->
    </action>
    <action name="v_ifcs_proximity_assist_toggle">
      <rebind input="js2_button64"/>  <!-- Toggle proximity assist (auto-slows near surfaces) - MTQ throttle DIAL back/CCW click. Paired with ESP on the same dial (63 = ESP, 64 = proximity). Moved off js1_button52 (AB6 left wing 4, now FREE) -->
    </action>

    <!-- Landing & Air Traffic Control -->
    <action name="v_atc_request">
      <rebind input="js2_button10"/>  <!-- Request landing (open hangar/pad). MTQ keypad "AP" - bottom-right key, next to the door/light/gear toggle strip (ground-ops cluster). Moved off js1_button53 (AB6 right wing 1, now FREE). The cargo-loading request (v_atc_loading_area_request) was REMOVED - never used, no docking/cargo-hauler use case -->
    </action>
    <action name="v_retract_landing_system">
      <rebind input="js2_button29"/>  <!-- Gear UP / retract (MTQ toggle C, up throw - the gear-shaped lever) -->
    </action>
    <action name="v_deploy_landing_system">
      <rebind input="js2_button30"/>  <!-- Gear DOWN / deploy (MTQ toggle C, down throw) -->
    </action>
    <action name="v_autoland">
      <rebind input="js2_button8"/>  <!-- Autoland (MTQ keypad, "ALT" label - altitude/approach fits). Moved from button 10. Landing gear toggle is now ONLY on the gear lever 29/30 -->
    </action>
    <!-- VTOL as a MAINTAINED 2-position switch on the MTQ Right Module 3-pos switch (rest 49 / forward-latch 50).
         Discrete on/off (NOT the toggle) so the switch position ALWAYS mirrors true VTOL state - flick forward to
         engage, return to rest to disengage. 49 (rest) re-fires v_vtol_off on every space-brake release (51 springs
         back through 49); harmless because _off is idempotent. Pulling back to brake therefore drops VTOL = a clean
         "abort to normal flight" gesture. Moved here off the COM-hat center press (js2_button57, now FREE). -->
    <action name="v_vtol_on">
      <rebind input="js2_button50"/>  <!-- VTOL ON - 3-pos switch FORWARD-LATCH (flick forward, stays latched) -->
    </action>
    <action name="v_vtol_off">
      <rebind input="js2_button49"/>  <!-- VTOL OFF - 3-pos switch REST/default. Re-fires on every brake release (idempotent, safe), so VTOL state always matches the physical switch position -->
    </action>
  </actionmap>

