<ActionMaps version="1" optionsVersion="2" rebindVersion="2" profileName="MOZA">
  <CustomisationUIHeader label="MOZA" description="MOZA MHG AB6 MTQ" image="">
    <devices>
      <joystick instance="1"/>
      <joystick instance="2"/>
    </devices>
    <categories />
  </CustomisationUIHeader>

  <options type="joystick" instance="1" Product="MOZA AB6 FFB Base  {1002346E-0000-0000-0000-504944564944}">
    <flight_move_pitch invert="0"/>
  </options>
  <options type="joystick" instance="2" Product="MOZA MTQ Throttle Panel  {1101346E-0000-0000-0000-504944564944}"/>

  <modifiers />

  <!-- ================================================================ -->
  <!-- POWER MANAGEMENT                                                 -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_power">
    <action name="v_power_toggle_weapons">
      <rebind input="js2_button1"/>  <!-- Weapons power on/off (MTQ keypad A1) -->
    </action>
    <action name="v_power_toggle_thrusters">
      <rebind input="js2_button2"/>  <!-- Thruster power on/off (MTQ keypad A2) -->
    </action>
    <action name="v_power_toggle_shields">
      <rebind input="js2_button3"/>  <!-- Shield power on/off (MTQ keypad A3) -->
    </action>
    <action name="v_power_set_off">
      <rebind input="js2_button23"/>  <!-- Master power OFF (MTQ 3-pos rocker LEFT position). Mirrors Flight Ready = master ON on button 24; button 22 = center/resting = intentionally unbound -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- SHIP SYSTEMS & UTILITIES                                         -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_general">
    <action name="v_flightready">
      <rebind input="js2_button24"/>  <!-- Flight ready - one-button startup sequence -->
    </action>
    <action name="v_unlock_all_doors">
      <rebind input="js2_button25"/>  <!-- Unlock all doors -->
    </action>
    <action name="v_open_all_doors">
      <rebind input="js2_button25"/>  <!-- Open all doors (combined with unlock) -->
    </action>
    <action name="v_lock_all_doors">
      <rebind input="js2_button26"/>  <!-- Lock all doors -->
    </action>
    <action name="v_close_all_doors">
      <rebind input="js2_button26"/>  <!-- Close all doors (combined with lock) -->
    </action>
  </actionmap>

  <actionmap name="lights_controller">
    <action name="v_lights_on">
      <rebind input="js2_button27"/>  <!-- Lights ON (MTQ toggle B, up throw). Repurposed from item-port unlock -->
    </action>
    <action name="v_lights_off">
      <rebind input="js2_button28"/>  <!-- Lights OFF (MTQ toggle B, down throw). Repurposed from item-port lock -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- FLIGHT CONTROLS & MOVEMENT                                       -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_movement">
    <!-- Primary Flight Controls (MHG Stick - Axes) -->
    <action name="v_pitch">
      <rebind input="js1_y"/>  <!-- Pitch up/down -->
    </action>
    <action name="v_roll">
      <rebind input="js1_x"/>  <!-- Roll left/right -->
    </action>
    <action name="v_yaw">
      <rebind input="js1_rotz"/>  <!-- Yaw left/right (twist) -->
    </action>

    <!-- Strafe Controls (MHG Stick - Hat Switch) -->
    <action name="v_strafe_up">
      <rebind input="js1_button12"/>  <!-- Strafe up -->
    </action>
    <action name="v_strafe_down">
      <rebind input="js1_button14"/>  <!-- Strafe down -->
    </action>
    <action name="v_strafe_right">
      <rebind input="js1_button13"/>  <!-- Strafe right -->
    </action>
    <action name="v_strafe_left">
      <rebind input="js1_button15"/>  <!-- Strafe left -->
    </action>

    <!-- Throttle & Speed (MTQ Throttle) -->
    <action name="v_strafe_forward">
      <rebind input="js2_roty"/>  <!-- Main throttle axis - forward/backward -->
    </action>
    <action name="v_strafe_back">
      <rebind input="js2_button34"/>  <!-- Override backward strafe -->
    </action>
    <action name="v_space_brake">
      <rebind input="js2_button51"/>  <!-- Space brake - full stop -->
    </action>
    <action name="v_afterburner">
      <rebind input="js2_button65"/>  <!-- Afterburner boost -->
    </action>
    <action name="v_toggle_jump_request">
      <rebind input="js1_button56"/>  <!-- Engage jump-point (inter-system) travel, e.g. Stanton/Pyro. NOT in-system quantum (js2_button7). Physical: AB6 right wing bottom button -->
    </action>

    <!-- Master Mode (NAV vs SCM) -->
    <action name="v_master_mode_cycle">
      <rebind input="js2_button5"/>  <!-- Cycle master mode - NAV (travel/quantum) vs SCM (combat) -->
    </action>

    <!-- Speed Limiter Controls -->
    <action name="v_ifcs_speed_limiter_increment">
      <rebind input="js2_button12"/>  <!-- Increase speed limiter -->
    </action>
    <action name="v_ifcs_speed_limiter_decrement">
      <rebind input="js2_button11"/>  <!-- Decrease speed limiter -->
    </action>
    <action name="v_ifcs_speed_limiter_toggle">
      <rebind input="js2_button13"/>  <!-- Enable/disable the speed limiter (MTQ upper encoder CENTER PRESS). Self-contained dial: turn 11/12 to set the speed cap, push 13 to switch the cap on/off -->
    </action>

    <!-- Acceleration G-Force Limiter -->
    <action name="v_accel_range_increment">
      <rebind input="js2_button15"/>  <!-- Increase G-force limiter -->
    </action>
    <action name="v_accel_range_decrement">
      <rebind input="js2_button14"/>  <!-- Decrease G-force limiter -->
    </action>

    <!-- Flight Control Assists -->
    <action name="v_ifcs_vector_decoupling_toggle">
      <rebind input="js1_button49"/>  <!-- Toggle coupled/decoupled mode - drift vs auto-stabilize -->
    </action>
    <action name="v_ifcs_toggle_esp">
      <rebind input="js1_button50"/>  <!-- Toggle ESP - dampens input for precise aiming -->
    </action>
    <action name="v_ifcs_toggle_gforce_safety">
      <rebind input="js2_button16"/>  <!-- Toggle G-Safe (MTQ lower encoder CENTER PRESS). Self-contained dial: turn 14/15 to set the accel/G cap, push 16 to toggle the G-safety that governs it. MOVED here from js1_button51 (AB6 left wing 3), which is now FREE -->
    </action>
    <action name="v_ifcs_proximity_assist_toggle">
      <rebind input="js1_button52"/>  <!-- Toggle proximity assist - auto-slows near objects -->
    </action>

    <!-- Landing & Air Traffic Control -->
    <action name="v_atc_request">
      <rebind input="js1_button53"/>  <!-- Request landing permission -->
    </action>
    <action name="v_atc_loading_area_request">
      <rebind input="js1_button54"/>  <!-- Request hangar/loading area -->
    </action>
    <action name="v_retract_landing_system">
      <rebind input="js2_button29"/>  <!-- Gear UP / retract (MTQ toggle C, up throw - the gear-shaped lever) -->
    </action>
    <action name="v_deploy_landing_system">
      <rebind input="js2_button30"/>  <!-- Gear DOWN / deploy (MTQ toggle C, down throw) -->
    </action>
    <action name="v_autoland">
      <rebind input="js2_button8"/>  <!-- Autoland (MTQ keypad, "ALT" label - altitude/approach fits). Moved from button 10. Landing gear toggle is now ONLY on the gear lever 29/30 -->
    </action>
    <action name="v_vtol_toggle">
      <rebind input="js2_button4"/>  <!-- VTOL thrust-mode toggle (MTQ keypad A4). VTOL-capable ships only -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- QUANTUM TRAVEL & NAVIGATION                                      -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_quantum">
    <action name="v_toggle_qdrive_engagement">
      <rebind input="js2_button7"/>  <!-- Engage/disengage quantum drive (MTQ keypad "SPD" label - speed/quantum, loose match) -->
    </action>
  </actionmap>

  <actionmap name="spaceship_hud">
    <action name="v_starmap">
      <rebind input="js2_button6"/>  <!-- Open starmap for navigation -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- MODE SWITCHING                                                   -->
  <!-- ================================================================ -->
  <actionmap name="seat_general">
    <action name="v_toggle_missile_mode">
      <rebind input="js1_button4"/>  <!-- Toggle between gun mode and missile mode -->
    </action>
    <!-- MTQ rotary mode-selector knob (5 detents = buttons 17-21, physically engraved 1-5 on the dial:
         17=pos1/full CCW ... 21=pos5/full CW). Each detent directly SETS one operator mode. Maintained
         selector: the knob position may not match the actual operator mode after seat entry or another
         mode change; turn off-and-back onto a detent to re-assert it. Operator modes are separate from
         Master Mode (SCM/NAV, cycled on js2_button5). -->
    <action name="v_set_guns_mode">
      <rebind input="js2_button17"/>  <!-- Detent 1 (full CCW) = Guns operator mode. Default park/rest position -->
    </action>
    <action name="v_set_missile_mode">
      <rebind input="js2_button18"/>  <!-- Detent 2 = Missile operator mode (also quick gun<->missile toggle on js1_button4) -->
    </action>
    <action name="v_set_scan_mode">
      <rebind input="js2_button19"/>  <!-- Detent 3 (center) = Scan operator mode -->
    </action>
    <action name="v_set_mining_mode">
      <rebind input="js2_button20"/>  <!-- Detent 4 = Mining operator mode (mining-capable ships) -->
    </action>
    <action name="v_set_salvage_mode">
      <rebind input="js2_button21"/>  <!-- Detent 5 (full CW) = Salvage operator mode (salvage-capable ships) -->
    </action>
    <action name="v_light_amplification_toggle">
      <rebind input="js1_button55"/>  <!-- LAMP toggle - light amplification (AB6 left slider pos 1) -->
    </action>
    <action name="v_light_amplification_off">
      <rebind input="js1_button59"/>  <!-- LAMP off - light amplification (AB6 left slider pos 3) -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- TARGETING - BASIC (lock, pin, auto-targeting)                    -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_targeting">
    <action name="v_target_lock_selected">
      <rebind input="js1_button11"/>  <!-- Lock onto selected target -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- TARGETING - ADVANCED (cycling & reticle selection)               -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_targeting_advanced">
    <action name="v_target_under_reticle">
      <rebind input="js1_button5"/>  <!-- Target whatever is under your crosshair -->
    </action>
    <action name="v_target_cycle_hostile_fwd">
      <rebind input="js1_button8"/>  <!-- Cycle to next hostile target -->
    </action>
    <action name="v_target_cycle_hostile_back">
      <rebind input="js1_button10"/>  <!-- Cycle to previous hostile target -->
    </action>
    <action name="v_target_cycle_subitem_fwd">
      <rebind input="js2_button9"/>  <!-- Cycle SUB-TARGETS / components of the locked ship (MTQ keypad, "FD" label). Focus-fire thrusters/weapons/power plant to disable -->
    </action>
    <action name="v_target_cycle_attacker_fwd">
      <rebind input="js2_button10"/>  <!-- Cycle ATTACKERS - lock whoever is currently shooting you (MTQ keypad "AP" label) -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- RADAR & SCANNING                                                 -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_radar">
    <action name="v_invoke_ping">
      <rebind input="js1_button20"/>  <!-- Radar ping - reveals nearby contacts -->
    </action>
  </actionmap>

  <actionmap name="spaceship_scanning">
    <action name="v_scanning_trigger_scan">
      <rebind input="js1_button18"/>  <!-- Hold to scan target/area -->
    </action>
    <action name="v_inc_scan_focus_level">
      <rebind input="js1_button17"/>  <!-- Narrow scan angle (more focused) -->
    </action>
    <action name="v_dec_scan_focus_level">
      <rebind input="js1_button19"/>  <!-- Widen scan angle (broader area) -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- WEAPONS & COMBAT SYSTEMS                                         -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_weapons">
    <action name="v_weapon_preset_fire_guns0">
      <rebind input="js1_button1"/>  <!-- Fire weapon group 1 (the 0/1 suffix = weapon GROUP, not trigger stage) -->
    </action>
    <action name="v_weapon_preset_fire_guns1">
      <rebind input="js1_button6"/>  <!-- Fire weapon group 2 (a separate weapon group; here placed on the trigger 2nd stage) -->
    </action>
    <action name="v_weapon_preset_next">
      <rebind input="js1_button22"/>  <!-- Next weapon group / next missile type in missile mode -->
    </action>
    <action name="v_weapon_preset_prev">
      <rebind input="js1_button23"/>  <!-- Previous weapon group / prev missile type in missile mode -->
    </action>
    <action name="v_weapon_aim_type_cycle">
      <rebind input="js1_button24"/>  <!-- Cycle aiming mode (fixed/gimbal/auto) -->
    </action>
    <action name="v_weapon_gimbals_state_toggle">
      <rebind input="js1_button16"/>  <!-- Toggle gimbal lock - fixed vs auto-aim -->
    </action>
  </actionmap>

  <actionmap name="spaceship_missiles">
    <action name="v_weapon_toggle_launch_missile">
      <rebind input="js1_button2"/>  <!-- Launch missile -->
    </action>
    <action name="v_weapon_cycle_missile_fwd">
      <rebind input="js1_button22"/>  <!-- Next missile type (shared with weapon preset in missile mode) -->
    </action>
    <action name="v_weapon_cycle_missile_back">
      <rebind input="js1_button23"/>  <!-- Previous missile type (shared with weapon preset in missile mode) -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- DEFENSIVE SYSTEMS                                                -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_defensive">
    <action name="v_weapon_countermeasure_decoy_launch">
      <rebind input="js1_button7"/>  <!-- Launch decoy countermeasure (vs missiles) -->
    </action>
    <action name="v_weapon_countermeasure_noise_launch">
      <rebind input="js1_button9"/>  <!-- Launch noise countermeasure (vs radar lock) -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- VIEW & CAMERA CONTROLS                                           -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_view">
    <action name="v_view_cycle_fwd">
      <rebind input="js1_button29"/>  <!-- Cycle camera views (1st person, 3rd person, etc) -->
    </action>
    <action name="v_view_freelook_mode">
      <rebind input="js1_button3"/>  <!-- Hold to freelook (look around cockpit) -->
    </action>
    <action name="v_view_pitch_up">
      <rebind input="js1_button25" activationMode="hold"/>  <!-- Look up (hold) -->
    </action>
    <action name="v_view_pitch_down">
      <rebind input="js1_button27" activationMode="hold"/>  <!-- Look down (hold) -->
    </action>
    <action name="v_view_yaw_left">
      <rebind input="js1_button28" activationMode="hold"/>  <!-- Look left (hold) -->
    </action>
    <action name="v_view_yaw_right">
      <rebind input="js1_button26" activationMode="hold"/>  <!-- Look right (hold) -->
    </action>
    <action name="v_view_zoom_in">
      <rebind input="js2_button63"/>  <!-- Zoom in -->
    </action>
    <action name="v_view_zoom_out">
      <rebind input="js2_button64"/>  <!-- Zoom out -->
    </action>
    <action name="v_ads_toggle">
      <rebind input="js1_button21"/>  <!-- Toggle zoomed cockpit view (binoculars) -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- PLAYER CONTROLS (on foot)                                        -->
  <!-- ================================================================ -->
  <actionmap name="player">
    <action name="zoom_in">
      <rebind input="js2_button63"/>  <!-- Zoom in (on foot) -->
    </action>
    <action name="zoom_out">
      <rebind input="js2_button64"/>  <!-- Zoom out (on foot) -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- SPECTATOR CONTROLS                                               -->
  <!-- ================================================================ -->
  <actionmap name="spectator">
    <action name="spectate_zoom_in">
      <rebind input="js2_button63"/>  <!-- Spectator zoom in -->
    </action>
    <action name="spectate_zoom_out">
      <rebind input="js2_button64"/>  <!-- Spectator zoom out -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- PLAYER CHOICE CONTROLS                                           -->
  <!-- ================================================================ -->
  <actionmap name="player_choice">
    <action name="pc_zoom_in">
      <rebind input="js2_button63"/>  <!-- Player choice zoom in -->
    </action>
    <action name="pc_zoom_out">
      <rebind input="js2_button64"/>  <!-- Player choice zoom out -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- MINING CONTROLS (mode-specific duplicates)                       -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_mining">
    <action name="v_toggle_mining_laser_fire">
      <rebind input="js1_button1"/>  <!-- Mining laser fire (reuse trigger) -->
    </action>
    <action name="v_increase_mining_throttle">
      <rebind input="js1_button22"/>  <!-- Increase mining laser power (reuse weapon next) -->
    </action>
    <action name="v_decrease_mining_throttle">
      <rebind input="js1_button23"/>  <!-- Decrease mining laser power (reuse weapon prev) -->
    </action>
    <action name="v_toggle_mining_laser_type">
      <rebind input="js1_button4"/>  <!-- Toggle mining laser type (reuse missile/gun mode toggle) -->
    </action>
    <action name="v_toggle_mining_mode">
      <rebind input="js1_button18"/>  <!-- PLACEHOLDER: Mining Mode toggle (replaced the invalid v_toggle_mining_mode_fracture). NOTE: v_toggle_mining_mode is really a seat_general action and button 18 is also the scan trigger; re-home this to seat_general on a dedicated free button when wiring mining properly -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- SALVAGE CONTROLS (mode-specific duplicates)                      -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_salvage">
    <action name="v_salvage_toggle_fire_focused">
      <rebind input="js1_button1"/>  <!-- Salvage focused beam fire (reuse trigger) -->
    </action>
    <action name="v_salvage_toggle_gimbal_mode">
      <rebind input="js1_button6"/>  <!-- Toggle salvage gimbal mode (reuse secondary fire) -->
    </action>
    <action name="v_salvage_toggle_fire_disintegrate">
      <rebind input="js1_button10"/>  <!-- Disintegrate material (reuse cycle hostile target back) -->
    </action>
    <action name="v_salvage_toggle_fire_fracture">
      <rebind input="js1_button8"/>  <!-- Fracture material (reuse cycle hostile target fwd) -->
    </action>
    <action name="v_salvage_cycle_modifiers_focused">
      <rebind input="js1_button11"/>  <!-- Cycle salvage modifier mode (reuse target lock) -->
    </action>
  </actionmap>
</ActionMaps>
