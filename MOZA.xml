<ActionMaps version="1" optionsVersion="2" rebindVersion="2" profileName="MOZA">
  <CustomisationUIHeader label="MOZA" description="MOZA MHG AB6 MTQ" image="">
    <devices>
      <joystick instance="1"/>
      <joystick instance="2"/>
    </devices>
    <categories />
  </CustomisationUIHeader>

  <options type="joystick" instance="1" Product="MOZA AB6 FFB Base  {1002346E-0000-0000-0000-504944564944}"/>  <!-- js1 pitch left at default (non-inverted = pull-back/nose-up); removed the no-op invert="0". To flip pitch later, add a child element here: <flight_move_pitch invert="1"/> -->
  <options type="joystick" instance="2" Product="MOZA MTQ Throttle Panel  {1101346E-0000-0000-0000-504944564944}">
    <flight_view_pitch invert="1"/>  <!-- Inverts camera-look PITCH (MTQ Left Module mini-stick Y axis / v_view_pitch). If pitch does NOT flip after a profile reload this element name is wrong - fall back to inverting js2_y in MOZA Pithouse (nothing else uses that axis). -->
  </options>

  <modifiers />

  <!-- ================================================================ -->
  <!-- POWER MANAGEMENT                                                 -->
  <!-- ================================================================ -->
  <!-- MTQ bottom-centre 3-position rocker (22/23/24): LEFT (23) = master power OFF (below), RIGHT (24) = Flight Ready / power ON (v_flightready in spaceship_general), CENTRE (22) = rest, intentionally UNBOUND (a binding there would fire on every return-to-centre). -->
  <actionmap name="spaceship_power">
    <action name="v_power_toggle_weapons">
      <rebind input="js2_button1"/>  <!-- MTQ keypad A1 - weapons power on/off (only meaningful in SCM; weapons stow in NAV) -->
    </action>
    <action name="v_power_toggle_thrusters">
      <rebind input="js2_button2"/>  <!-- MTQ keypad A2 - thruster power on/off (off = can't manoeuvre, lower engine signature / cold running) -->
    </action>
    <action name="v_power_toggle_shields">
      <rebind input="js2_button3"/>  <!-- MTQ keypad A3 - shield power on/off (re-enable incurs a boot delay; shields are offline in NAV regardless) -->
    </action>
    <action name="v_power_set_off">
      <rebind input="js2_button23"/>  <!-- MTQ 3-pos rocker LEFT - master power OFF (discrete SET, always off, not a toggle) -->
    </action>
    <!-- POWER-PIP TRIANGLE on the MTQ Right Module "WPN" hat (thumb-reachable mid-fight). Moved here off the AB6 wings, REPLACING the old shield-faceting that only did anything on rare Size-3-shield ships - this pip system works on EVERY ship (F8C/Origin included). Tap toward the system you need, RIGHT=reset to rebalance, press-HOLD=slam shields for a burst-tank. No decrease binds (reset rebalances). ACTIONMAP NOTE: v_engineering_assignment_* live in spaceship_power (catalogue files them with the working v_power_* under "flight - power"); verify in-game if a direction does nothing. -->
    <action name="v_engineering_assignment_weapons_increase">
      <rebind input="js2_button56"/>  <!-- MTQ "WPN" hat UP - power to WEAPONS + (tap) -->
    </action>
    <action name="v_engineering_assignment_shields_increase">
      <rebind input="js2_button55"/>  <!-- MTQ "WPN" hat DOWN - power to SHIELDS + (tap) -->
    </action>
    <action name="v_engineering_assignment_engine_increase">
      <rebind input="js2_button54"/>  <!-- MTQ "WPN" hat LEFT - power to ENGINES + (tap) -->
    </action>
    <action name="v_engineering_assignment_reset">
      <rebind input="js2_button53"/>  <!-- MTQ "WPN" hat RIGHT - RESET power allocation to balanced/even -->
    </action>
    <action name="v_engineering_assignment_shields_max">
      <rebind input="js2_button52"/>  <!-- MTQ "WPN" hat CENTER PRESS - HOLD to slam all power to SHIELDS (burst-tank an incoming hit; returns on release) -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- SHIP SYSTEMS & UTILITIES                                         -->
  <!-- ================================================================ -->
  <!-- MTQ lower-strip toggle A (metal 2-pos): UP (25) "opens up the ship", DOWN (26) "seals the ship"; each throw fires TWO actions at once (by design). -->
  <actionmap name="spaceship_general">
    <action name="v_flightready">
      <rebind input="js2_button24"/>  <!-- MTQ 3-pos rocker RIGHT - Flight Ready / power ON: one-press startup (power+avionics+engines+shields). Toggle - press again to spin down. Pairs with master-OFF on rocker LEFT (23). -->
    </action>
    <action name="v_unlock_all_doors">
      <rebind input="js2_button25"/>  <!-- MTQ toggle A UP - unlock all doors (shares this throw with v_open_all_doors) -->
    </action>
    <action name="v_open_all_doors">
      <rebind input="js2_button25"/>  <!-- MTQ toggle A UP - open all doors/ramps (shares this throw with v_unlock_all_doors) -->
    </action>
    <action name="v_lock_all_doors">
      <rebind input="js2_button26"/>  <!-- MTQ toggle A DOWN - lock all doors (shares this throw with v_close_all_doors) -->
    </action>
    <action name="v_close_all_doors">
      <rebind input="js2_button26"/>  <!-- MTQ toggle A DOWN - close all doors/ramps (shares this throw with v_lock_all_doors) -->
    </action>
  </actionmap>

  <actionmap name="lights_controller">
    <action name="v_lights_on">
      <rebind input="js2_button27"/>  <!-- MTQ toggle B UP - exterior/interior lights ON (discrete) -->
    </action>
    <action name="v_lights_off">
      <rebind input="js2_button28"/>  <!-- MTQ toggle B DOWN - lights OFF / run dark (visual only, not EM/IR stealth) -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- FLIGHT CONTROLS & MOVEMENT                                       -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_movement">
    <!-- Primary flight axes on the MHG stick (js1). Pitch invert is set in the js1 <options> block at the top. -->
    <action name="v_pitch">
      <rebind input="js1_y"/>  <!-- MHG stick Y axis - pitch (nose up/down; pull back = nose up) -->
    </action>
    <action name="v_roll">
      <rebind input="js1_x"/>  <!-- MHG stick X axis - roll (bank left/right) -->
    </action>
    <action name="v_yaw">
      <rebind input="js1_rotz"/>  <!-- MHG stick TWIST (Z-rotation) - yaw (nose left/right) -->
    </action>

    <!-- Strafe directions on the MTQ Right Module "COM" hat (the larger hat, 57-61). Moved off the MHG right hat (js1 12/13/14/15, now targeting). Hat CENTRE PRESS (57) = decoupling toggle, see Flight Control Assists below. -->
    <action name="v_strafe_up">
      <rebind input="js2_button61"/>  <!-- MTQ "COM" hat UP - strafe up (translate, no rotation) -->
    </action>
    <action name="v_strafe_down">
      <rebind input="js2_button60"/>  <!-- MTQ "COM" hat DOWN - strafe down -->
    </action>
    <action name="v_strafe_right">
      <rebind input="js2_button58"/>  <!-- MTQ "COM" hat RIGHT - strafe right -->
    </action>
    <action name="v_strafe_left">
      <rebind input="js2_button59"/>  <!-- MTQ "COM" hat LEFT - strafe left -->
    </action>

    <!-- Throttle reverse is BINARY by necessity (fully investigated): the MTQ throttle is a unidirectional 0-65535 axis idling at ~12%, never goes negative, and Pithouse cannot recenter it; SC locks neutral to axis-CENTRE (32767) with only center-symmetric options - so a full-range v_strafe_longitudinal would read idle as deep reverse. Hence forward = axis (js2_roty), reverse = rear-detent button (js2_button34). Requires MOZA "Detent Button Mapping" ON so the rear detent emits button 34. -->
    <action name="v_strafe_forward">
      <rebind input="js2_roty"/>  <!-- MTQ main throttle lever axis (RY) - forward throttle, idle at bottom = 0 thrust. Its synced twin js2_rotx (RX) is intentionally left UNBOUND. -->
    </action>
    <action name="v_strafe_back">
      <rebind input="js2_button34"/>  <!-- MTQ throttle REAR DETENT - reverse / throttle-decrease (binary - see note above) -->
    </action>
    <action name="v_space_brake">
      <rebind input="js2_button51"/>  <!-- MTQ Right Module 3-pos switch, MOMENTARY-BACK - space brake / full stop. Hold to brake; springs back through rest (49 = v_vtol_off, idempotent so re-firing is harmless). Switch rest (49) = VTOL off, forward-latch (50) = VTOL on - see the VTOL block below. -->
    </action>
    <action name="v_afterburner">
      <rebind input="js2_button65"/>  <!-- MTQ Left Module face button - afterburner / boost (depletable pool; also overrides proximity assist while held) -->
    </action>
    <action name="v_toggle_jump_request">
      <rebind input="js2_button9"/>  <!-- MTQ keypad "FD" - engage inter-system JUMP-POINT travel (e.g. Stanton<->Pyro), NOT in-system quantum (that's "SPD"/7). Sits directly below the quantum key to form a travel column. Moved off js1_button56 (now an AB6 multi-mode wing: targeting/mining/salvage). -->
    </action>

    <!-- Master Mode (NAV vs SCM) -->
    <action name="v_master_mode_cycle">
      <rebind input="js2_button5"/>  <!-- MTQ keypad "NAV" - cycle master mode: SCM (combat, weapons/shields) <-> NAV (travel, quantum, higher speed, weapons offline) -->
    </action>

    <!-- Speed limiter on the MTQ UPPER encoder - self-contained dial: turn 11/12 to set the cap, push 13 to engage/release it. -->
    <action name="v_ifcs_speed_limiter_increment">
      <rebind input="js2_button12"/>  <!-- MTQ upper encoder CW - raise the SCM speed cap -->
    </action>
    <action name="v_ifcs_speed_limiter_decrement">
      <rebind input="js2_button11"/>  <!-- MTQ upper encoder CCW - lower the speed cap (fly slow/precise, tighter turns) -->
    </action>
    <action name="v_ifcs_speed_limiter_toggle">
      <rebind input="js2_button13"/>  <!-- MTQ upper encoder CENTER PRESS - enable/disable the speed cap (instant full-speed sprint or back to capped) -->
    </action>

    <!-- Acceleration/G-force limiter on the MTQ LOWER encoder - self-contained dial: turn 14/15 to set the cap, push 16 to toggle the G-safety that governs it. -->
    <action name="v_accel_range_increment">
      <rebind input="js2_button15"/>  <!-- MTQ lower encoder CW - raise the accel/G cap (snappier, harsher Gs) -->
    </action>
    <action name="v_accel_range_decrement">
      <rebind input="js2_button14"/>  <!-- MTQ lower encoder CCW - lower the accel/G cap (smoother, safer from blackout) -->
    </action>

    <!-- Flight Control Assists -->
    <!-- Decoupling toggle on the MTQ "COM" strafe-hat CENTRE PRESS (57) - co-located with the strafe directions (decoupled = pure Newtonian translation, the mode you enable to strafe freely while keeping guns on a target). Moved off AB6 left wing 1 (js1_button49, now an AB6 multi-mode wing: targeting/mining/salvage). Deliberately NOT on the 3-pos switch 49/50: that switch's rest re-fires on every brake release, which would force-RECOUPLE every brake; 57 is a plain press, so decoupled survives braking. -->
    <action name="v_ifcs_vector_decoupling_toggle">
      <rebind input="js2_button57"/>  <!-- MTQ "COM" hat CENTER PRESS - toggle coupled/decoupled flight -->
    </action>
    <action name="v_ifcs_toggle_gforce_safety">
      <rebind input="js2_button16"/>  <!-- MTQ lower encoder CENTER PRESS - toggle G-Safe (caps manoeuvres to prevent blackout; off = full performance, blackout risk). Moved here from js1_button51 (now an AB6 multi-mode wing: targeting/mining/salvage). -->
    </action>
    <!-- ESP and proximity-assist toggles are intentionally LEFT UNBOUND: the user keeps both ENABLED by default in SC settings and never toggles them. v_ifcs_toggle_esp previously sat on keypad A4 (now returned to LAMP); v_ifcs_proximity_assist_toggle is also a confirmed no-op in 4.x. -->

    <!-- Landing & ATC -->
    <action name="v_atc_request">
      <rebind input="js2_button10"/>  <!-- MTQ keypad "AP" - request landing (hails ATC, opens hangar/pad/forcefields in range). Bottom-right of the ground-ops keypad cluster. Moved off js1_button53 (now an AB6 multi-mode wing: targeting/mining/salvage). Cargo-loading request (v_atc_loading_area_request) was REMOVED - never used. -->
    </action>
    <action name="v_retract_landing_system">
      <rebind input="js2_button29"/>  <!-- MTQ toggle C (gear-shaped lever) UP - landing gear RETRACT (lever position mirrors gear state) -->
    </action>
    <action name="v_deploy_landing_system">
      <rebind input="js2_button30"/>  <!-- MTQ toggle C (gear-shaped lever) DOWN - landing gear DEPLOY (lever down = gear down, aircraft convention) -->
    </action>
    <action name="v_autoland">
      <rebind input="js2_button8"/>  <!-- MTQ keypad "ALT" - autoland (autopilot lands on an ATC pad when gear is down and you're close). Gear toggle is now ONLY on the gear lever (29/30). -->
    </action>
    <!-- VTOL as a MAINTAINED 2-position state on the MTQ Right Module 3-pos switch (rest 49 / forward-latch 50): discrete on/off (NOT the toggle) so the switch position ALWAYS mirrors true VTOL state. Rest (49) re-fires v_vtol_off on every space-brake release (51 springs back through 49) - harmless because _off is idempotent; pulling back to brake therefore cleanly drops VTOL (an "abort to normal flight" gesture). Moved off the COM-hat press (js2_button57, now decoupling). -->
    <action name="v_vtol_on">
      <rebind input="js2_button50"/>  <!-- MTQ 3-pos switch FORWARD-LATCH - VTOL ON (flick forward, stays latched) -->
    </action>
    <action name="v_vtol_off">
      <rebind input="js2_button49"/>  <!-- MTQ 3-pos switch REST/default - VTOL OFF (idempotent SET; re-fires harmlessly on every brake release so VTOL state always matches the physical switch position) -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- QUANTUM TRAVEL & NAVIGATION                                      -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_quantum">
    <action name="v_toggle_qdrive_engagement">
      <rebind input="js2_button7"/>  <!-- MTQ keypad "SPD" - engage/disengage quantum drive for IN-SYSTEM travel (needs NAV mode + an aligned marker). "SPD"/speed label = loose quantum match. -->
    </action>
  </actionmap>

  <actionmap name="spaceship_hud">
    <action name="v_starmap">
      <rebind input="js2_button6"/>  <!-- MTQ keypad "HDG" - open the starmap (mobiGlas) to pick a quantum destination. "HDG"/heading label = loose nav match. -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- MODE SWITCHING & LAMP                                            -->
  <!-- ================================================================ -->
  <!-- MTQ rotary mode-selector knob: 5 detents = buttons 17-21, physically engraved 1-5 (17 = pos1/full CCW ... 21 = pos5/full CW). Each detent directly SETS one operator mode. Maintained selector - the knob position may not match the actual operator mode after seat entry or another mode change; turn off-and-back onto a detent to re-assert it. Operator modes are separate from Master Mode (SCM/NAV, on js2_button5). -->
  <actionmap name="seat_general">
    <action name="v_toggle_missile_mode">
      <rebind input="js1_button4"/>  <!-- MHG upper thumb button - quick gun<->missile mode flip (knob detents 17/18 SET them explicitly; this same button = switch mining laser in Mining mode) -->
    </action>
    <action name="v_set_guns_mode">
      <rebind input="js2_button17"/>  <!-- MTQ mode knob detent 1 (full CCW) - Guns operator mode. Default park/rest position (combat-ready). -->
    </action>
    <action name="v_set_missile_mode">
      <rebind input="js2_button18"/>  <!-- MTQ mode knob detent 2 - Missile operator mode (also the quick toggle on js1_button4) -->
    </action>
    <action name="v_set_scan_mode">
      <rebind input="js2_button19"/>  <!-- MTQ mode knob detent 3 (centre) - Scan operator mode (radar/ping) -->
    </action>
    <action name="v_set_mining_mode">
      <rebind input="js2_button20"/>  <!-- MTQ mode knob detent 4 - Mining operator mode (mining-capable ships) -->
    </action>
    <action name="v_set_salvage_mode">
      <rebind input="js2_button21"/>  <!-- MTQ mode knob detent 5 (full CW) - Salvage operator mode (salvage-capable ships) -->
    </action>
    <action name="v_light_amplification_toggle">
      <rebind input="js2_button4"/>  <!-- MTQ keypad "A4" - LAMP canopy night-vision toggle (LAMP-equipped ships). Back on A4 after ESP was unbound; the earlier LAMP/lights-switch pairing was dropped (27/28 are lights-only again). -->
    </action>
    <action name="v_view_look_behind">
      <rebind input="js1_button3"/>  <!-- MHG lower side button (pinky) - HOLD for rear-view camera. MUST live in seat_general, NOT spaceship_view: despite the v_view_ prefix, CIG files look-behind under "seats & operator modes" (catalogue confirms), and the first attempt in spaceship_view silently did nothing. REPLACED v_view_freelook_mode (which genuinely IS a spaceship_view action - hence the map swap): freelook detached the view from ship facing, and an unconscious pinky-hold felt like losing control. Look-behind keeps FULL stick/flight control (camera swings rear, snaps back on release). Bare binding - hold is the action's native behavior; add activationMode="hold" only if it doesn't behave as hold. -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- TARGETING - BASIC (lock, pin, auto-targeting)                    -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_targeting">
    <action name="v_target_lock_selected">
      <rebind input="js1_button11"/>  <!-- MHG left hat CENTER PRESS - hard-lock the selected target (lead pips + missile lock). Also = cycle salvage modifiers in Salvage mode. -->
    </action>
    <action name="v_target_pin_selected">
      <rebind input="js1_button29"/>  <!-- MHG coolie CENTER PRESS - pin the current target (cycle back to it later via coolie LEFT). MUST be in spaceship_targeting, NOT spaceship_targeting_advanced: the game's exported actionmaps.xml DROPS pin from the advanced map (so pinning did nothing) and files it here with the basic lock action. Confirmed accepted on reload. -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- TARGETING - ADVANCED (cycling & reticle selection)               -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_targeting_advanced">
    <action name="v_target_under_reticle">
      <rebind input="js1_button5"/>  <!-- MHG lower-centre face button - lock whatever is under the crosshair ("target what I'm aiming at") -->
    </action>
    <action name="v_target_cycle_hostile_fwd">
      <rebind input="js1_button8"/>  <!-- MHG left hat RIGHT - cycle to next hostile (also = fire salvage FRACTURE beam in Salvage mode) -->
    </action>
    <action name="v_target_cycle_hostile_back">
      <rebind input="js1_button10"/>  <!-- MHG left hat LEFT - cycle to previous hostile (also = fire salvage DISINTEGRATE beam in Salvage mode) -->
    </action>
    <action name="v_target_cycle_subitem_fwd">
      <rebind input="js1_button12"/>  <!-- MHG right hat UP - cycle SUB-TARGETS forward (components: thrusters/weapons/power plant to focus-fire) -->
    </action>
    <action name="v_target_cycle_subitem_back">
      <rebind input="js1_button14"/>  <!-- MHG right hat DOWN - cycle SUB-TARGETS back (completes the up/down pair with 12) -->
    </action>
    <action name="v_target_cycle_attacker_fwd">
      <rebind input="js1_button13"/>  <!-- MHG right hat RIGHT - cycle ATTACKERS forward (snap to whoever is shooting you) -->
    </action>
    <action name="v_target_cycle_attacker_back">
      <rebind input="js1_button15"/>  <!-- MHG right hat LEFT - cycle ATTACKERS back (completes the right/left pair with 13) -->
    </action>
    <!-- MHG top coolie hat (4-way + press) = TARGET ACQUISITION cluster, freed when camera-look moved to the MTQ mini-stick; thumb-reachable mid-dogfight, complements the left hat's hostile-cycle/lock. NOTE: the coolie CENTER PRESS (v_target_pin_selected) is bound in the spaceship_targeting actionmap (with v_target_lock_selected) - the game DROPS pin from spaceship_targeting_advanced, so only the 4 directional presses live in this map. -->
    <action name="v_target_cycle_all_fwd">
      <rebind input="js1_button25"/>  <!-- MHG coolie UP - cycle ALL contacts forward (any vehicle in scanner range, not just hostiles) -->
    </action>
    <action name="v_target_cycle_all_back">
      <rebind input="js1_button27"/>  <!-- MHG coolie DOWN - cycle ALL contacts back -->
    </action>
    <action name="v_target_cycle_hostile_reset">
      <rebind input="js1_button26"/>  <!-- MHG coolie RIGHT - snap-lock the CLOSEST hostile (the best panic-target button in a furball) -->
    </action>
    <action name="v_target_cycle_pinned_fwd">
      <rebind input="js1_button28"/>  <!-- MHG coolie LEFT - cycle PINNED targets forward -->
    </action>
    <!-- v_target_pin_selected (MHG coolie CENTER PRESS, js1_button29) is bound in the spaceship_targeting actionmap, NOT here - the game DROPS pin from spaceship_targeting_advanced. See that block and the note above. -->
    <!-- AB6 base wings (8 momentary pushbuttons) - in COMBAT a secondary target-acquisition bank (all cycle actions, distinct from the hats); the SAME buttons become the Mining/Salvage control banks in those operator modes (see spaceship_mining / spaceship_salvage). Multi-mode reuse is double-fire-safe because targeting maps go inactive in mining/salvage modes (proven by the left hat's hostile-cycle vs salvage-beam reuse). -->
    <action name="v_target_cycle_in_view_fwd">
      <rebind input="js1_button49"/>  <!-- AB6 LEFT wing 1 - cycle targets IN VIEW forward (forward-arc contacts) -->
    </action>
    <action name="v_target_cycle_in_view_back">
      <rebind input="js1_button50"/>  <!-- AB6 LEFT wing 2 - cycle targets IN VIEW back -->
    </action>
    <action name="v_target_cycle_all_reset">
      <rebind input="js1_button51"/>  <!-- AB6 LEFT wing 3 - lock CLOSEST contact of any type -->
    </action>
    <action name="v_target_cycle_attacker_reset">
      <rebind input="js1_button52"/>  <!-- AB6 LEFT wing 4 - lock CLOSEST attacker -->
    </action>
    <action name="v_target_cycle_friendly_fwd">
      <rebind input="js1_button53"/>  <!-- AB6 RIGHT wing 1 - cycle FRIENDLIES forward (escort/support) -->
    </action>
    <action name="v_target_cycle_friendly_back">
      <rebind input="js1_button54"/>  <!-- AB6 RIGHT wing 2 - cycle FRIENDLIES back -->
    </action>
    <action name="v_target_cycle_pinned_back">
      <rebind input="js1_button55"/>  <!-- AB6 RIGHT wing 3 - cycle PINNED targets back (pairs with coolie LEFT = pinned forward) -->
    </action>
    <action name="v_target_cycle_subitem_reset">
      <rebind input="js1_button56"/>  <!-- AB6 RIGHT wing 4 - reset SUB-TARGET back to the main hull -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- RADAR & SCANNING                                                 -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_radar">
    <action name="v_invoke_ping">
      <rebind input="js1_button20"/>  <!-- MHG lower hat LEFT - active radar ping (reveals nearby contacts by cross-section; also reveals you) -->
    </action>
  </actionmap>

  <actionmap name="spaceship_scanning">
    <action name="v_scanning_trigger_scan">
      <rebind input="js1_button18"/>  <!-- MHG lower hat RIGHT - HOLD to scan the target/area under the reticle (Scan operator mode). Same button = mining-mode toggle in Mining mode. -->
    </action>
    <action name="v_inc_scan_focus_level">
      <rebind input="js1_button17"/>  <!-- MHG lower hat UP - narrow the scan cone (stronger/longer-range read) -->
    </action>
    <action name="v_dec_scan_focus_level">
      <rebind input="js1_button19"/>  <!-- MHG lower hat DOWN - widen the scan cone (broader sweep) -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- WEAPONS & COMBAT SYSTEMS                                         -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_weapons">
    <action name="v_weapon_preset_fire_guns0">
      <rebind input="js1_button1"/>  <!-- MHG main TRIGGER (stage 1) - fire weapon group 1 (0/1 suffix = weapon GROUP, not trigger stage). Same trigger = mining laser / salvage focused beam in those modes. -->
    </action>
    <action name="v_weapon_preset_fire_guns1">
      <rebind input="js1_button6"/>  <!-- MHG trigger STAGE 2 (front pull) - fire weapon group 2. Same control = toggle salvage gimbal in Salvage mode. -->
    </action>
    <action name="v_weapon_preset_next">
      <rebind input="js1_button22"/>  <!-- MHG upper rocker UP - next weapon group (also next missile type in missile mode / mining power + in Mining mode) -->
    </action>
    <action name="v_weapon_preset_prev">
      <rebind input="js1_button23"/>  <!-- MHG upper rocker DOWN - previous weapon group (also prev missile type / mining power -) -->
    </action>
    <action name="v_weapon_aim_type_cycle">
      <rebind input="js1_button24"/>  <!-- MHG upper rocker CENTER - cycle aim mode (fixed / gimbal-assist / manual gimbal) -->
    </action>
    <action name="v_weapon_gimbals_state_toggle">
      <rebind input="js1_button16"/>  <!-- MHG right hat CENTER PRESS - toggle gimbal lock (locked = tighter convergence vs auto-aim) -->
    </action>
  </actionmap>

  <actionmap name="spaceship_missiles">
    <action name="v_weapon_toggle_launch_missile">
      <rebind input="js1_button2"/>  <!-- MHG top-left face button - launch missile (HOLD to build a stronger lock before release) -->
    </action>
    <action name="v_weapon_cycle_missile_fwd">
      <rebind input="js1_button22"/>  <!-- MHG upper rocker UP - next missile type (shares 22 with weapon-preset-next; active operator mode decides) -->
    </action>
    <action name="v_weapon_cycle_missile_back">
      <rebind input="js1_button23"/>  <!-- MHG upper rocker DOWN - prev missile type (shares 23 with weapon-preset-prev) -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- DEFENSIVE SYSTEMS                                                -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_defensive">
    <action name="v_weapon_countermeasure_decoy_launch">
      <rebind input="js1_button7"/>  <!-- MHG left hat UP - launch DECOY/flares (lure IR/cross-section seeker missiles) -->
    </action>
    <action name="v_weapon_countermeasure_noise_launch">
      <rebind input="js1_button9"/>  <!-- MHG left hat DOWN - launch NOISE/chaff (break radar/scan locks) -->
    </action>
    <!-- Shield FACETING (v_shield_raise_level_*) was REMOVED from the "WPN" hat: confirmed it only does anything on ships with Size 3+ shield generators (quad-faced, e.g. Carrack/Constellation/Hull-C); every fighter the user flies (F8C, Origin = Size 1/2 single-bubble shields) treats it as a no-op. The "WPN" hat now drives the universal power-pip triangle (see spaceship_power) - shield STRENGTH is managed there on every ship. Countermeasures (decoy/noise) stay on the MHG left hat. -->
  </actionmap>

  <!-- ================================================================ -->
  <!-- VIEW & CAMERA CONTROLS                                           -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_view">
    <action name="v_view_cycle_fwd">
      <rebind input="js2_button62"/>  <!-- MTQ Left Module mini-stick PRESS - cycle camera view (cockpit <-> external/chase). Moved off MHG coolie press js1_button29 (now = pin target). -->
    </action>
    <!-- view_restore_defaults was REMOVED from here (it shared js2_button62): the game DROPS it from spaceship_view, so it did nothing - the cockpit recentre-on-view-cycle is v_view_cycle_fwd's own behaviour. It is only accepted in the view_director_mode actionmap (the cinematic/Director camera), which this combat profile doesn't use. -->
    <!-- Camera look on the MTQ Left Module analog mini-stick (axes js2_x/js2_y, centres at 32767 = neutral, so no off-centre calibration needed - unlike the throttle). Moved off the MHG top coolie hat (js1 25/26/27/28, now target acquisition). Pitch is inverted via flight_view_pitch in the js2 <options> block at the top of this file. -->
    <action name="v_view_yaw">
      <rebind input="js2_x"/>  <!-- MTQ mini-stick X axis - look left/right -->
    </action>
    <action name="v_view_pitch">
      <rebind input="js2_y"/>  <!-- MTQ mini-stick Y axis - look up/down (inverted in <options>) -->
    </action>
    <!-- MTQ throttle-lever thumb dial (incremental encoder: each click pulses 63 fwd/CW or 64 back/CCW - momentary, no hold). Drives dynamic FOV zoom, which works in the COCKPIT. (Removed the v_view_zoom_in/out 3rd-person camera-distance pair that used to ride along here per click - confirmed dead in testing.) 3rd-person FoV zoom is NOT achievable here anyway - it needs a HELD modifier (kb F4) and a momentary click can't hold; use the keyboard or a Pithouse "hold F4 + tap NumPad +/-" macro for that. -->
    <action name="v_view_dynamic_zoom_rel_in">
      <rebind input="js2_button63"/>  <!-- MTQ throttle dial FWD/CW - dynamic FOV zoom IN (works in cockpit) -->
    </action>
    <action name="v_view_dynamic_zoom_rel_out">
      <rebind input="js2_button64"/>  <!-- MTQ throttle dial BACK/CCW - dynamic FOV zoom OUT (works in cockpit) -->
    </action>
    <action name="v_ads_toggle">
      <rebind input="js1_button21"/>  <!-- MHG lower hat CENTER PRESS - toggle zoomed cockpit/"ADS" view (the reliable in-cockpit zoom) -->
    </action>
  </actionmap>

  <!-- On-foot zoom maps (player/spectator/player_choice) were removed - the rig is vehicle-only (CLAUDE.md S1) and those actions can't fire from a seat anyway. -->

  <!-- ================================================================ -->
  <!-- MINING CONTROLS (mode-specific duplicates)                       -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_mining">
    <action name="v_toggle_mining_laser_fire">
      <rebind input="js1_button1"/>  <!-- MHG main trigger - fire mining laser (reuses the gun trigger; Mining mode only) -->
    </action>
    <action name="v_increase_mining_throttle">
      <rebind input="js1_button22"/>  <!-- MHG upper rocker UP - mining laser power + (superseded by the FLAPS axis when that's set; this rocker is also weapon-preset in combat / salvage beam-spacing in Salvage mode) -->
    </action>
    <action name="v_decrease_mining_throttle">
      <rebind input="js1_button23"/>  <!-- MHG upper rocker DOWN - mining laser power - (rocker reused per operator mode, see above) -->
    </action>
    <!-- Mining laser power as an ABSOLUTE AXIS on the MTQ FLAPS slider (far-right, maintained lever) - hold power proportionally in the green fracture window instead of tapping the rocker. CONFIRMED in Golem: FLAPS = js2_slider2 (joy.cpl calls it "Slider", SC enumerates it as slider2 NOT slider1). Direction correct, NO invert: rest (up) = ~20% (the laser's minimum throttle floor, a game mechanic) -> FULL (down) = 100%. Supersedes the stepped +/- on js1_button22/23 when both are live. The slider's own detent buttons (36-40) are intentionally UNBOUND - the axis covers it. -->
    <action name="v_mining_throttle">
      <rebind input="js2_slider2"/>  <!-- MTQ FLAPS slider axis ("Slider") - absolute mining laser power -->
    </action>
    <action name="v_toggle_mining_laser_type">
      <rebind input="js1_button4"/>  <!-- MHG upper thumb button - switch mining laser head/module (reuses the missile/gun mode toggle) -->
    </action>
    <!-- REMOVED the v_toggle_mining_mode placeholder that was on js1_button18: it was in the wrong action map (belongs to seat_general), shared the scan trigger, and was redundant with the mode knob's v_set_mining_mode (js2_button20). Mining mode is selected on the knob; nothing else needed here. -->
    <!-- AB6 base wings as the MINING control bank (same buttons = targeting in combat / salvage in salvage mode): activate fitted mining modules + emergency cargo dump. -->
    <action name="v_mining_use_consumable1">
      <rebind input="js1_button49"/>  <!-- AB6 LEFT wing 1 - activate mining module slot 1 -->
    </action>
    <action name="v_mining_use_consumable2">
      <rebind input="js1_button50"/>  <!-- AB6 LEFT wing 2 - activate mining module slot 2 -->
    </action>
    <action name="v_mining_use_consumable3">
      <rebind input="js1_button51"/>  <!-- AB6 LEFT wing 3 - activate mining module slot 3 -->
    </action>
    <action name="v_jettison_volatile_cargo">
      <rebind input="js1_button52"/>  <!-- AB6 LEFT wing 4 - JETTISON volatile cargo (emergency dump of unstable Quantanium etc.) -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- SALVAGE CONTROLS (mode-specific duplicates)                      -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_salvage">
    <action name="v_salvage_toggle_fire_focused">
      <rebind input="js1_button1"/>  <!-- MHG main trigger - fire focused salvage beam (reuses the gun trigger; Salvage mode only) -->
    </action>
    <action name="v_salvage_toggle_gimbal_mode">
      <rebind input="js1_button6"/>  <!-- MHG trigger stage 2 - toggle salvage gimbal mode -->
    </action>
    <action name="v_salvage_toggle_fire_disintegrate">
      <rebind input="js1_button10"/>  <!-- MHG left hat LEFT - fire DISINTEGRATE beam (break down material) -->
    </action>
    <action name="v_salvage_toggle_fire_fracture">
      <rebind input="js1_button8"/>  <!-- MHG left hat RIGHT - fire FRACTURE beam (crack structures into salvageable pieces) -->
    </action>
    <action name="v_salvage_cycle_modifiers_focused">
      <rebind input="js1_button11"/>  <!-- MHG left hat CENTER PRESS - cycle focused salvage modifier (e.g. scraper vs tractor) -->
    </action>
    <!-- Salvage beam spacing as an ABSOLUTE AXIS on the MTQ SPEEDBRAKE slider (far-left, maintained lever) - set the gap to match the hull panel and leave it. CONFIRMED in Salvation: SPEEDBRAKE = js2_slider1 (joy.cpl calls it "Dial", SC enumerates it as slider1). Full lever travel = full spacing range, auto-mapped, no calibration/range needed; direction is preference. The slider's own detent buttons (31/43) are intentionally UNBOUND - the axis covers it. -->
    <action name="v_salvage_beam_spacing_abs">
      <rebind input="js2_slider1"/>  <!-- MTQ SPEEDBRAKE slider axis ("Dial") - absolute salvage beam spacing -->
    </action>
    <!-- Stepped beam spacing on the MHG upper rocker (reused: weapon-preset in combat, mining power in Mining, beam-spacing here) - fine-trim on top of the SPEEDBRAKE absolute axis. -->
    <action name="v_salvage_increase_beam_spacing">
      <rebind input="js1_button22"/>  <!-- MHG upper rocker UP - salvage beam spacing + (wider gap) -->
    </action>
    <action name="v_salvage_decrease_beam_spacing">
      <rebind input="js1_button23"/>  <!-- MHG upper rocker DOWN - salvage beam spacing - (narrower gap) -->
    </action>
    <!-- AB6 base wings as the SALVAGE control bank (same buttons = targeting in combat / mining in mining mode): focus heads, fire individual beams, gimbal/axis/structural controls. -->
    <action name="v_salvage_focus_all_heads">
      <rebind input="js1_button49"/>  <!-- AB6 LEFT wing 1 - focus ALL salvage heads -->
    </action>
    <action name="v_salvage_focus_left">
      <rebind input="js1_button50"/>  <!-- AB6 LEFT wing 2 - focus LEFT salvage head only -->
    </action>
    <action name="v_salvage_focus_right">
      <rebind input="js1_button51"/>  <!-- AB6 LEFT wing 3 - focus RIGHT salvage head only -->
    </action>
    <action name="v_salvage_toggle_beam_spacing_axis">
      <rebind input="js1_button52"/>  <!-- AB6 LEFT wing 4 - toggle beam axis (parallel horizontal <-> vertical) -->
    </action>
    <action name="v_salvage_toggle_fire_left">
      <rebind input="js1_button53"/>  <!-- AB6 RIGHT wing 1 - toggle-fire LEFT beam (regardless of focus) -->
    </action>
    <action name="v_salvage_toggle_fire_right">
      <rebind input="js1_button54"/>  <!-- AB6 RIGHT wing 2 - toggle-fire RIGHT beam (regardless of focus) -->
    </action>
    <action name="v_salvage_reset_gimbal">
      <rebind input="js1_button55"/>  <!-- AB6 RIGHT wing 3 - reset salvage gimbal to centre -->
    </action>
    <action name="v_salvage_cycle_modifiers_structural">
      <rebind input="js1_button56"/>  <!-- AB6 RIGHT wing 4 - cycle STRUCTURAL salvage modes -->
    </action>
  </actionmap>

  <!-- ONLY REMAINING UNBOUND js1 hardware = the two AB6 base levers (intentional): each is MIXED-MODE - 3 detent buttons AND a continuous analog axis. Left "Slider" = detents 57 (top/100) / 58 / 59 (bottom/0); right "Dial" = detents 60 (top/full) / 61 / 62 (bottom/0); analog halves are js1_slider1 / js1_slider2 (which lever is which needs joy.cpl confirmation, same counter-intuitive mapping as the MTQ). Reserved for a future modal/analog use - maintained set-and-hold levers suit neither momentary combat actions nor analog values combat doesn't need. Everything else on js1 is now bound: MHG grip 1-29 fully bound; AB6 wings 49-56 are the multi-mode bank (targeting in combat / mining / salvage). -->
  <!-- DUPE/REUSE POLICY: a physical button carrying several actions is fine ONLY when they sit in operator-gated maps that are never simultaneously active - guns/missiles/mining/salvage/targeting are gated by operator mode, so the trigger, rocker, hats and AB6 wings each do one thing per mode. spaceship_power/defensive/movement/view/general are ALWAYS active, so their controls (WPN-hat power pips, left-hat countermeasures, MTQ throttle/strafe/encoders) are NOT reused for mining/salvage. No action is bound to two different inputs. Intentional same-map "shotgun": MTQ doors (25/26) = unlock+open / lock+close. (The zoom dial 63/64 is no longer a shotgun - its dead 3rd-person view_zoom pair was removed, so each click now fires one action.) -->
</ActionMaps>
