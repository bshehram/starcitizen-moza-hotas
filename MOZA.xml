    </action>
    <action name="v_increase_mining_throttle">
      <rebind input="js1_button22"/>  <!-- Increase mining laser power (reuse weapon next) -->
    </action>
    <action name="v_decrease_mining_throttle">
      <rebind input="js1_button23"/>  <!-- Decrease mining laser power (reuse weapon prev) -->
    </action>
    <!-- Mining laser power as an ABSOLUTE AXIS on the FLAPS slider (far-right). Hold power proportionally in the green
         fracture window instead of tapping the +/- rocker. CONFIRMED in-game (Golem): FLAPS = js2_slider2 (joy.cpl calls
         it the "Slider" axis, but SC enumerates it as slider2, not slider1). The synced throttle pair is js2_rotx/js2_roty
         - not these sliders. DIRECTION CONFIRMED CORRECT - NO invert needed: lever at rest (up) = laser charge ~20%,
         pushed to FULL (down) = 100% (v_mining_throttle reads the axis opposite to the flight throttle, so it just works).
         The ~20% at rest is the mining laser's minimum throttle floor - a game mechanic, not a binding issue, and harmless
         (the laser only emits while firing). Supersedes the stepped inc/dec on js1_button22/23 above (absolute axis wins
         when both are live). -->
    <action name="v_mining_throttle">
      <rebind input="js2_slider2"/>  <!-- FLAPS slider = absolute mining laser power -->
    </action>
    <action name="v_toggle_mining_laser_type">
      <rebind input="js1_button4"/>  <!-- Toggle mining laser type (reuse missile/gun mode toggle) -->
    </action>
    <action name="v_toggle_mining_mode">
      <rebind input="js1_button18"/>  <!-- PLACEHOLDER: Mining Mode toggle (replaced the invalid v_toggle_mining_mode_fracture). NOTE: v_toggle_mining_mode is really a seat_general action and button 18 is also the scan trigger; re-home this to seat_general on a dedicated free button when wiring mining properly -->
    </action>
  </actionmap>

