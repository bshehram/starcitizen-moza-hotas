  <!-- ================================================================ -->
  <!-- DEFENSIVE SYSTEMS                                                -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_defensive">
    <action name="v_weapon_countermeasure_decoy_launch">
      <rebind input="js1_button7"/>  <!-- Launch decoy countermeasure (vs missiles) -->
    </action>
    <action name="v_weapon_countermeasure_noise_launch">
      <rebind input="js1_button9"/>  <!-- Launch noise countermeasure (vs radar lock) -->
    </action>

    <!-- Shield faceting on the MTQ "WPN" hat (52-56) - push the hat toward a threat to stack shields that way.
         Directions map 1:1 to the hat: 56 up = front, 55 down = rear, 54 left = port, 53 right = starboard,
         52 press = reset/equalize. Ships with single-bubble shields ignore the directional raises; the reset is
         harmless there. -->
    <action name="v_shield_raise_level_forward">
      <rebind input="js2_button56"/>  <!-- Raise FRONT shield (WPN hat UP) -->
    </action>
    <action name="v_shield_raise_level_back">
      <rebind input="js2_button55"/>  <!-- Raise REAR shield (WPN hat DOWN) -->
    </action>
    <action name="v_shield_raise_level_left">
      <rebind input="js2_button54"/>  <!-- Raise PORT/left shield (WPN hat LEFT) -->
    </action>
    <action name="v_shield_raise_level_right">
      <rebind input="js2_button53"/>  <!-- Raise STARBOARD/right shield (WPN hat RIGHT) -->
    </action>
    <action name="v_shield_reset_level">
      <rebind input="js2_button52"/>  <!-- Reset/equalize shield levels (WPN hat CENTER PRESS) -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- VIEW & CAMERA CONTROLS                                           -->
  <!-- ================================================================ -->
  <actionmap name="spaceship_view">
    <action name="v_view_cycle_fwd">
      <rebind input="js2_button62"/>  <!-- Cycle camera view (cockpit <-> external). MTQ Left Module mini-stick PRESS. Moved off MHG coolie press js1_button29 -->
    </action>
    <action name="v_view_freelook_mode">
