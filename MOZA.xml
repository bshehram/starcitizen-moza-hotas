    </action>
    <action name="v_power_set_off">
      <rebind input="js2_button23"/>  <!-- Master power OFF (MTQ 3-pos rocker LEFT position). Mirrors Flight Ready = master ON on button 24; button 22 = center/resting = intentionally unbound -->
    </action>
  </actionmap>

  <!-- ================================================================ -->
  <!-- SHIP SYSTEMS & UTILITIES                                         -->
  <!-- ================================================================ -->
