  <!-- ================================================================ -->
  <!-- MODE SWITCHING                                                   -->
  <!-- ================================================================ -->
  <actionmap name="seat_general">
    <action name="v_toggle_missile_mode">
      <rebind input="js1_button4"/>  <!-- Toggle between gun mode and missile mode -->
    </action>
    <!-- MTQ rotary mode-selector knob (5 detents = buttons 17-21, physically engraved 1-5 on the dial:
         17=pos1/full CCW ... 21=pos5/full CW). Each detent directly SETS one operator mode. Maintained
         selector: the knob position may not match the actual operator mode after seat entry or another
         mode change; turn off-and-back onto a detent to re-assert it. Operator modes are separate from
         Master Mode (SCM/NAV, cycled on js2_button5). -->
    <action name="v_set_guns_mode">
      <rebind input="js2_button17"/>  <!-- Detent 1 (full CCW) = Guns operator mode. Default park/rest position -->
    </action>
    <action name="v_set_missile_mode">
      <rebind input="js2_button18"/>  <!-- Detent 2 = Missile operator mode (also quick gun<->missile toggle on js1_button4) -->
    </action>
    <action name="v_set_scan_mode">
      <rebind input="js2_button19"/>  <!-- Detent 3 (center) = Scan operator mode -->
    </action>
    <action name="v_set_mining_mode">
      <rebind input="js2_button20"/>  <!-- Detent 4 = Mining operator mode (mining-capable ships) -->
    </action>
    <action name="v_set_salvage_mode">
      <rebind input="js2_button21"/>  <!-- Detent 5 (full CW) = Salvage operator mode (salvage-capable ships) -->
    </action>
    <action name="v_light_amplification_toggle">
      <rebind input="js2_button4"/>  <!-- LAMP toggle - canopy night-vision (MTQ keypad "A4"). Moved off js1_button55 (AB6 right wing 3, now FREE); A4 was vacated by VTOL -->
    </action>
    <action name="v_light_amplification_off">
      <rebind input="js1_button59"/>  <!-- LAMP off - light amplification (AB6 left slider pos 3) -->
    </action>
  </actionmap>

